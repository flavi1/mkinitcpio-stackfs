DEST="/mnt/artefix"
SRC_DIR=$(pwd)

cleanup() {
    echo ""
    echo "::: Nettoyage de l'environnement Artefix :::"
    # On démonte tout ce qui est lié à DEST. 
    # sort -r permet de démonter les couches overlay avant le tmpfs de base.
    mount | grep "$DEST" | awk '{print $3}' | sort -r | xargs -r sudo umount -l
    echo "::: Système propre. :::"
}

trap cleanup EXIT

echo "::: Préparation du Chroot Artefix :::"

# 1. Montage via ton orchestrateur
# Note : mnt-stackfs monte déjà /dev, /proc, /sys, /run et /boot !
sudo ./src/1_artefix.ro/usr/bin/mnt-stackfs \
     --type bind \
     --src "$SRC_DIR" \
     --boot /boot \
     --target stackfs \
     --dest "$DEST"

if [ $? -ne 0 ]; then
    echo "Erreur lors du montage."
    exit 1
fi

# 2. LE PETIT AJOUT : La résolution DNS
# mnt-stackfs ne gère pas le réseau. Pour pacman, il faut copier le resolv.conf
if [ -f /etc/resolv.conf ]; then
    sudo cp /etc/resolv.conf "$DEST/etc/resolv.conf"
fi

echo "::: Entrée dans le système (Exit pour quitter) :::"

# 3. Entrée dans le chroot
# On force TERM pour avoir les couleurs et une expérience shell propre
sudo chroot "$DEST" /usr/bin/env TERM="$TERM" /usr/bin/bash --login

# Le cleanup auto s'occupe du reste.
