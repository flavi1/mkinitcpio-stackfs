#!/usr/bin/bash
# SPDX-License-Identifier: GPL-2.0-only
# Copyright (C) 2026-present Guillon Flavien

# --- DEFAULTS ---
TYPE="bind"
BOOT_DIR="/boot"
TARGET_NAME="stackfs"
LOGFILE=""
DEST="/new_root"
SRC_MOUNT="" 

usage() {
    echo "Usage: $0 [options]"
    echo "Options:"
    echo "  --type [bind|move]  (default: bind)"
    echo "  --boot [path]       (default: /boot)"
    echo "  --target [name]     (default: stackfs)"
    echo "  --log [path]        (optional)"
    echo "  --dest [path]       (default: /new_root)"
    echo "  --src [path]        (Point de montage du disque physique)"
    exit 1
}

while [[ "$#" -gt 0 ]]; do
    case $1 in
        --type)   TYPE="$2"; shift ;;
        --boot)   BOOT_DIR="$2"; shift ;;
        --target) TARGET_NAME="$2"; shift ;;
        --log)    LOGFILE="$2"; shift ;;
        --dest)   DEST="$2"; shift ;;
        --src)    SRC_MOUNT="$2"; shift ;;
        *) usage ;;
    esac
    shift
done

[ -z "$SRC_MOUNT" ] && echo "Erreur: --src est obligatoire" && exit 1

if [ -n "$LOGFILE" ]; then
    exec > >(tee -a "$LOGFILE") 2>&1
fi

MNT_OP="--$TYPE"
TARGET_PATH="${SRC_MOUNT}${BOOT_DIR}/${TARGET_NAME}"

echo "::: StackFS Orchestrator ($TYPE) :::"

# =========================================================
# INITIALISATION DU TMPFS DESTINATION
# =========================================================
mkdir -p "$DEST"
mount -t tmpfs -o size=128M tmpfs "$DEST" # Augmenté à 128M pour plus de flexibilité

BOOT_DISK_MNT="${DEST}/.boot_disk"
PREMOUNT_MNT="${DEST}/.premount"
VOLATILE_BASE="${DEST}/tmp/fs_volatiles"
WORKDIR_BASE="${DEST}/tmp/fs_workdir"

mkdir -p "$BOOT_DISK_MNT" "$PREMOUNT_MNT" "$VOLATILE_BASE" "$WORKDIR_BASE"
mount "$MNT_OP" "$SRC_MOUNT" "$BOOT_DISK_MNT"

TARGET_PATH="${BOOT_DISK_MNT}${BOOT_DIR}/${TARGET_NAME}"

echo "--- Montage des couches ---"
for img in $(ls -1 "$TARGET_PATH" | sort); do
    mnt_p="${PREMOUNT_MNT}/$img"
    mkdir -p "$mnt_p"
    opts="loop,ro"
    [[ "$img" == *.rw ]] && opts="loop,rw"
    mount -o "$opts" "${TARGET_PATH}/$img" "$mnt_p"
done

echo "--- Fusion OverlayFS ---"

EXCLUDE_LIST="^\(\.boot_disk\|\.premount\|tmp\|mnt\|proc\|sys\|dev\|run\|media\|boot\|\.workdirs\)$"

# Récupération de toutes les entrées (plates ou normales) présentes dans les couches
all_entries=$(ls -A "${PREMOUNT_MNT}"/* | sed "s|^${PREMOUNT_MNT}/[^/]*/||" | grep -v "$EXCLUDE_LIST" | sort -u)
volatiles_queue=""

for entry in $all_entries; do
    layers=""
    last_layer=""
    is_rw=false
    count=0
    is_placeholder=false
    
    clean_entry=$(echo "$entry" | sed 's|^/||; s|/$||')
    
    # --- MODIFICATION 1 : LOGIQUE DE MAPPING __ VERS / ---
    # Si l'entrée contient '__', sa destination est transformée (ex: var__log -> var/log)
    logical_entry="${clean_entry//__//}"
    real_dest="${DEST}/${logical_entry}"

    for mnt in "${PREMOUNT_MNT}"/*; do
        # On doit chercher 'clean_entry' (flat) dans les .rw 
        # ET 'logical_entry' (standard) dans les .ro (base)
        if [[ "$(basename "$mnt")" == *.rw ]]; then
            src="${mnt}/${clean_entry}"
        else
            src="${mnt}/${logical_entry}"
        fi

        if [ -e "$src" ] || [ -L "$src" ]; then
            if [ -f "$src" ] && [ ! -s "$src" ]; then
                is_placeholder=true
            else
                layers="${src}:${layers}"
                last_layer="$src"
                [[ "$(basename "$mnt")" == *.rw ]] && is_rw=true || is_rw=false
                count=$((count + 1))
                is_placeholder=false
            fi
        fi
    done

    # --- ÉTAPE 1 : LIENS SYMBOLIQUES ---
    if [ -L "$last_layer" ]; then
        target=$(readlink "$last_layer")
        mkdir -p "$(dirname "$real_dest")"
        ln -sf "$target" "$real_dest"
        continue
    fi

    # --- ÉTAPE 2 : PLACEHOLDERS (RAM) ---
    if [ "$is_placeholder" = true ]; then
        volatiles_queue="$volatiles_queue $real_dest"
        continue
    fi

    layers=${layers%:}
    
    mkdir -p "$(dirname "$real_dest")" 2>/dev/null
    [ ! -d "$real_dest" ] && [ ! -f "$real_dest" ] && mkdir -p "$real_dest"

    if [ "$count" -eq 1 ]; then
        mount --bind "$last_layer" "$real_dest"
    elif [ "$count" -gt 1 ]; then
        if [ "$is_rw" = true ]; then
            # --- MODIFICATION 2 : WORKDIRS CENTRALISÉS ---
            # Le workdir est placé dans /.workdirs/ à la racine de la couche RW
            # On utilise le nom physique (clean_entry) pour éviter les collisions
            rw_root="$(dirname "$last_layer")"
            work_dir="${rw_root}/.workdirs/${clean_entry}"
            mkdir -p "$work_dir"
            
            lower=${layers#*:}
            mount -t overlay overlay -o lowerdir="$lower",upperdir="$last_layer",workdir="$work_dir" "$real_dest"
        else
            v_upper="${WORKDIR_BASE}/${clean_entry}_u"
            v_work="${WORKDIR_BASE}/${clean_entry}_w"
            mkdir -p "$v_upper" "$v_work"
            mount -t overlay overlay -o lowerdir="$layers",upperdir="$v_upper",workdir="$v_work" "$real_dest"
        fi
    fi
done

# --- RÉINITIALISATION DES RÉPERTOIRES STANDARDS ---
for s in mnt media tmp; do
    mkdir -p "${DEST}/$s"
done

# --- GESTION DES VOLATILES ---
for vol in $volatiles_queue; do
    rel_path=$(echo "$vol" | sed "s|^${DEST}||; s|^/||")
    storage="${VOLATILE_BASE}/${rel_path//\//_}"
    mkdir -p "$storage" "$vol"
    mount --bind "$storage" "$vol"
done

# --- SYSTÈMES VIRTUELS ---
for v in /proc /sys /dev /run; do
    if mountpoint -q "$v"; then
        mkdir -p "${DEST}${v}"
        mount "$MNT_OP" "$v" "${DEST}${v}"
    fi
done

# --- LIAISON DU BOOT PHYSIQUE ---
mkdir -p "${DEST}/boot"
mount --bind "${BOOT_DISK_MNT}${BOOT_DIR}" "${DEST}/boot"

echo "::: Orchestration terminée :::"
